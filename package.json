{
  "name": "bickspec-studio",
  "version": "0.1.0",
  "description": "A lightweight desktop IDE for writing, compiling, reviewing, and exporting BickSpec financial specifications, built with Electron, React, TypeScript, and the Spec Grid brand system.",
  "main": "out/main/index.js",
  "author": "BickSpec",
  "license": "UNLICENSED",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "typecheck": "tsc --noEmit",
    "build": "tsc --noEmit && electron-vite build",
    "preview": "electron-vite preview",
    "package:dir": "npm run build && electron-builder --dir",
    "package": "npm run build && electron-builder",
    "package:win": "npm run build && electron-builder --win",
    "package:mac": "npm run build && electron-builder --mac",
    "package:linux": "npm run build && electron-builder --linux",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "release": "npm run build && electron-builder --publish onTag"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "monaco-editor": "^0.52.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "electron": "^37.0.0",
    "electron-builder": "^26.0.0",
    "electron-vite": "^4.0.0",
    "typescript": "^5.8.0",
    "vite": "^7.0.0"
  },
  "build": {
    "appId": "com.bickspec.studio",
    "productName": "BickSpec Studio",
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "files": [
      "out/**",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build/icon.png",
        "to": "icon.png"
      },
      {
        "from": "build/icon.ico",
        "to": "icon.ico"
      },
      {
        "from": "docs",
        "to": "docs"
      }
    ],
    "mac": {
      "icon": "build/icon.png",
      "category": "public.app-category.developer-tools",
      "artifactName": "BickSpec-Studio-${version}-macOS-${arch}.${ext}",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "build/icon.ico",
      "artifactName": "BickSpec-Studio-${version}-Windows-${arch}.${ext}",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "shortcutName": "BickSpec Studio",
      "uninstallDisplayName": "BickSpec Studio",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "linux": {
      "icon": "build/icon.png",
      "target": [
        "AppImage"
      ]
    },
    "publish": {
      "provider": "github",
      "owner": "paolomarroq",
      "repo": "bickspec-studio",
      "releaseType": "draft"
    }
  }
}
